<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generador Brief OTEC</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- HTML2PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        .hidden { display: none !important; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans selection:bg-[#00205B]/10 selection:text-[#00205B]">

    <!-- ==================== VISTA CARGA ==================== -->
    <div id="view-loading" class="hidden min-h-screen bg-white flex-col items-center justify-center text-slate-900">
        <div class="w-6 h-6 border-2 border-[#00205B]/20 border-t-[#00205B] rounded-full animate-spin mb-4"></div>
        <p class="text-sm text-slate-500 tracking-wide font-medium">Estructurando campaña...</p>
    </div>

    <!-- ==================== VISTA REPORTE ==================== -->
    <div id="view-report" class="hidden min-h-screen bg-slate-100 text-slate-900 p-6 md:p-12">
        <div class="max-w-4xl mx-auto mb-6 flex items-center justify-between">
            <button onclick="setView('form')" class="flex items-center gap-2 text-sm text-slate-500 hover:text-[#00205B] transition-colors font-medium">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Volver a edición
            </button>
            <button id="btn-export-pdf" onclick="handlePrint()" class="flex items-center gap-2 bg-[#00205B] text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-[#00153D] transition-colors shadow-sm disabled:opacity-70">
                <i data-lucide="download" class="w-4 h-4" id="icon-download"></i>
                <i data-lucide="loader-2" class="w-4 h-4 animate-spin hidden" id="icon-loading"></i>
                <span id="text-export">Exportar a PDF</span>
            </button>
        </div>

        <div id="report-content" class="max-w-4xl mx-auto bg-white p-10 border border-slate-200 shadow-sm rounded-xl">
            <div class="space-y-10">
                <header class="border-b-2 border-slate-100 pb-6">
                    <div class="flex items-center gap-2 mb-2">
                        <div class="w-2 h-2 rounded-full bg-[#FFC72C]"></div>
                        <span class="text-xs font-bold text-[#00205B] uppercase tracking-widest">Documento Operativo</span>
                    </div>
                    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Brief de Campaña Digital</h1>
                    <p class="text-slate-500 mt-1">Requerimiento estructurado para campaña de Marketing.</p>
                </header>

                <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <h3 class="text-xs font-bold text-[#00205B] uppercase tracking-wider mb-4 flex items-center gap-2">
                            <i data-lucide="file-text" class="w-4 h-4"></i> Ficha Operativa
                        </h3>
                        <div class="space-y-3 text-sm bg-white p-5 rounded-lg border border-slate-200">
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-slate-500">Curso</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-curso">—</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-slate-500">Modalidad</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-modalidad">E-learning Asincrónico</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-slate-500">Inicio</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-inicio">—</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-slate-500">Extensión</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-horas">—</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-100 pb-2">
                                <span class="text-slate-500">Inversión</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-valor">$0</span>
                            </div>
                            <div class="flex justify-between pt-1">
                                <span class="text-slate-500">Quórum / Capacidad</span>
                                <span class="font-semibold text-right text-slate-900" id="rep-quorum">— min / — max</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-xs font-bold text-amber-600 uppercase tracking-wider mb-4 flex items-center gap-2">
                            <i data-lucide="alert-circle" class="w-4 h-4"></i> Normativa y Relatores
                        </h3>
                        <div class="bg-white border border-slate-200 rounded-lg p-5 space-y-4 text-sm">
                            <div>
                                <span class="text-slate-500 block mb-1">Estatus SENCE</span>
                                <span class="font-semibold text-slate-900" id="rep-sence">Sin Franquicia SENCE</span>
                            </div>
                            <div class="pt-3 border-t border-slate-100">
                                <span class="text-slate-500 block mb-2">Relatores Asignados</span>
                                <div id="rep-relatores-container" class="space-y-2">
                                    <span class="font-semibold text-slate-900">No se especifican relatores.</span>
                                </div>
                                <div id="rep-reuf-alert" class="mt-3 p-3 bg-white text-slate-800 border border-slate-200 rounded-md text-xs leading-relaxed font-medium hidden">
                                    <strong class="text-[#00205B] block mb-1">Acreditación Específica SENCE (REUF):</strong> 
                                    El facilitador debe estar inscrito en el Registro de Facilitadores (REUF). OTEC declara facilitador específico con perfil técnico. Sence autoriza la actividad basándose en sus competencias. Si no asiste, no se dicta con franquicia.
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section>
                    <h3 class="text-xs font-bold text-emerald-600 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <i data-lucide="users" class="w-4 h-4"></i> Estrategia de Copywriting
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="bg-white border border-slate-200 rounded-lg p-5">
                            <span class="text-xs font-semibold text-slate-500 block mb-2">Público Objetivo</span>
                            <p class="text-sm font-medium text-slate-800 leading-relaxed" id="rep-publico">—</p>
                        </div>
                        <div class="bg-white border border-slate-200 rounded-lg p-5">
                            <span class="text-xs font-semibold text-slate-500 block mb-2">Dolor a Resolver</span>
                            <p class="text-sm font-medium text-slate-800 leading-relaxed" id="rep-dolor">—</p>
                        </div>
                        <div class="bg-white border border-slate-200 rounded-lg p-5">
                            <span class="text-xs font-semibold text-slate-500 block mb-2">Promesa de Valor</span>
                            <p class="text-sm font-medium text-slate-800 leading-relaxed" id="rep-promesa">—</p>
                        </div>
                    </div>
                </section>

                <section>
                    <h3 class="text-xs font-bold text-purple-600 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <i data-lucide="image" class="w-4 h-4"></i> Requerimientos de Diseño Gráfico
                    </h3>
                    <div class="bg-white border border-slate-200 rounded-lg p-5">
                        <div class="mb-4">
                            <span class="text-slate-500 text-sm block mb-1">¿Requiere diseño específico?</span>
                            <span class="font-semibold text-slate-900 text-sm" id="rep-grafica-status">No (Usar gráficas estandar).</span>
                        </div>
                        <div id="rep-grafica-details" class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-slate-100 hidden">
                            <div>
                                <span class="text-slate-500 text-xs font-semibold block mb-2">Detalle de formatos</span>
                                <p class="text-sm font-medium text-slate-800 leading-relaxed" id="rep-formatos">—</p>
                            </div>
                            <div>
                                <span class="text-slate-500 text-xs font-semibold block mb-2">Comentarios adicionales</span>
                                <p class="text-sm font-medium text-slate-800 leading-relaxed" id="rep-comentarios">—</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <!-- ==================== VISTA EDICIÓN FORMULARIO ==================== -->
    <div id="view-form" class="min-h-screen pb-20">
        <div class="max-w-3xl mx-auto pt-16 px-6 lg:px-8">
            <header class="mb-12">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#FFC72C]/20 text-[#00205B] text-xs font-bold mb-4 uppercase tracking-wide">
                    Campaña Marketing
                </div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-2">Requerimientos de Campaña</h1>
                <p class="text-slate-500 text-sm">Completa la matriz operativa para el despliegue publicitario del curso.</p>
            </header>

            <form id="main-form" class="space-y-10">
                
                <!-- 1. Datos Operativos -->
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 border-b border-slate-100 pb-4 mb-6">
                        <div class="p-2 bg-[#00205B]/10 text-[#00205B] rounded-lg"><i data-lucide="file-text" class="w-5 h-5"></i></div>
                        01. Operaciones
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Nombre Oficial del Curso</label>
                            <input type="text" id="nombreCurso" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all" placeholder="Ej: Diplomado en Normativa Laboral">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Modalidad</label>
                            <select id="modalidad" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all cursor-pointer">
                                <option>E-learning Asincrónico</option>
                                <option>E-learning Sincrónico</option>
                                <option>Presencial</option>
                                <option>Mixta</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide flex items-center gap-2">Fecha de Inicio</label>
                            <input type="date" id="fechaInicio" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all disabled:opacity-50 disabled:bg-slate-100">
                            <label class="flex items-center gap-2 mt-2 text-xs font-medium text-slate-600 cursor-pointer hover:text-slate-900 transition-colors">
                                <input type="checkbox" id="siempreAbierto" class="w-4 h-4 text-[#00205B] rounded border-slate-300 focus:ring-[#00205B]">
                                Formato siempre abierto (E-learning)
                            </label>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Horas Totales</label>
                            <input type="number" id="horas" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all" placeholder="40">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Valor (CLP)</label>
                            <input type="number" id="valor" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all" placeholder="150000">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Mínima de estudiantes</label>
                            <input type="number" id="estudiantesMin" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all" placeholder="15">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Máximo de estudiantes</label>
                            <input type="number" id="estudiantesMax" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-[#00205B] focus:ring-2 focus:ring-[#00205B]/20 transition-all" placeholder="30">
                        </div>
                    </div>
                </section>

                <!-- 2. SENCE y Compliance -->
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 border-b border-slate-100 pb-4 mb-6">
                        <div class="p-2 bg-amber-50 text-amber-600 rounded-lg"><i data-lucide="alert-circle" class="w-5 h-5"></i></div>
                        02. Normativa SENCE y Relatores
                    </h2>
                    
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-4 bg-slate-50 border border-slate-200 rounded-xl">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-900">Franquicia SENCE</h3>
                                <p class="text-xs text-slate-500 mt-1">Define el uso de logos oficiales en pauta.</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="hasSence" class="sr-only peer">
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500"></div>
                            </label>
                        </div>

                        <div id="container-codigoSence" class="pt-2 hidden">
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Código SENCE Vigente</label>
                            <input type="text" id="codigoSence" class="w-full bg-amber-50/50 border border-amber-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-100 transition-all" placeholder="Ingresa el código numérico">
                        </div>

                        <div class="flex items-center justify-between p-4 bg-slate-50 border border-slate-200 rounded-xl mt-4">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-900">Relatores</h3>
                                <p class="text-xs text-slate-500 mt-1">Asignar facilitadores al programa para uso publicitario.</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="hasRelatores" class="sr-only peer">
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500"></div>
                            </label>
                        </div>

                        <div id="container-relatores" class="p-6 bg-amber-50/30 border border-amber-100 rounded-xl space-y-6 mt-4 hidden">
                            <div class="space-y-4">
                                <div id="relatores-list" class="space-y-4">
                                    <!-- Relatores dinámicos injectados aquí por JS -->
                                </div>
                                <button type="button" onclick="addRelator()" class="flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-100/50 px-4 py-2 rounded-lg hover:bg-amber-100 transition-colors border border-amber-200">
                                    <i data-lucide="plus" class="w-4 h-4"></i> Agregar relator
                                </button>
                            </div>

                            <div class="border-t border-amber-200/50 pt-5 space-y-4" id="container-reuf-sence">
                                <label class="flex items-start gap-3 cursor-pointer bg-red-50 p-4 rounded-lg border border-red-200">
                                    <input type="checkbox" id="relatorExclusivo" class="mt-0.5 w-4 h-4 text-red-600 rounded border-red-300 focus:ring-red-500">
                                    <div class="text-sm">
                                        <span class="font-bold text-red-800 block mb-1">Acreditación Específica (REUF SENCE)</span>
                                        <span class="text-red-700/90 text-xs leading-relaxed block">
                                            El facilitador <strong>debe estar inscrito en el Registro de Facilitadores (REUF)</strong>. Cuando un OTEC inscribe un curso (o una empresa lo comunica), debe declarar a un facilitador específico que cumpla con el perfil técnico solicitado. Sence autoriza la actividad basándose en las competencias de esa persona. <strong>Si es exclusivo y no asiste, el curso no se dicta con franquicia.</strong>
                                        </span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- 3. Insumos Copywriting -->
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 border-b border-slate-100 pb-4 mb-6">
                        <div class="p-2 bg-emerald-50 text-emerald-600 rounded-lg"><i data-lucide="users" class="w-5 h-5"></i></div>
                        03. Estructura de Copywriting
                    </h2>
                    <div class="space-y-5">
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Público Objetivo</label>
                            <textarea id="publicoObjetivo" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 transition-all resize-none" placeholder="Perfiles y cargos específicos..."></textarea>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Dolor del Cliente</label>
                            <textarea id="dolorCliente" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 transition-all resize-none" placeholder="Problema operativo o normativo que enfrentan..."></textarea>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Promesa de Valor</label>
                            <textarea id="promesaValor" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 transition-all resize-none" placeholder="Competencia adquirida al finalizar..."></textarea>
                        </div>
                    </div>
                </section>

                <!-- 4. Activos Gráficos -->
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2 border-b border-slate-100 pb-4 mb-6">
                        <div class="p-2 bg-purple-50 text-purple-600 rounded-lg"><i data-lucide="image" class="w-5 h-5"></i></div>
                        04. Material Gráfico
                    </h2>
                    <div class="space-y-4">
                        <div class="p-5 bg-slate-50 border border-slate-200 rounded-xl">
                            <label class="flex flex-col sm:flex-row sm:items-center justify-between cursor-pointer">
                                <div>
                                    <span class="text-sm font-semibold text-slate-900 block">¿Requiere una gráfica especial?</span>
                                    <span class="text-xs text-slate-500 mt-1">Desarrollo de nuevas piezas o formatos.</span>
                                </div>
                                <div class="relative inline-flex items-center mt-3 sm:mt-0">
                                    <input type="checkbox" id="graficaEspecial" class="sr-only peer">
                                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-purple-600"></div>
                                </div>
                            </label>
                            
                            <div id="container-graficaDetalles" class="hidden">
                                <div class="mt-6 space-y-5 pt-5 border-t border-slate-200">
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Detalle de la gráfica requerida</label>
                                        <textarea id="detalleGraficas" rows="2" class="w-full bg-white border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-100 transition-all resize-none" placeholder="Dimensiones y plataformas..."></textarea>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-700 mb-2 uppercase tracking-wide">Comentarios</label>
                                        <textarea id="comentariosGrafica" rows="2" class="w-full bg-white border border-slate-200 rounded-lg p-3 text-sm text-slate-900 focus:outline-none focus:border-purple-500 focus:ring-2 focus:ring-purple-100 transition-all resize-none" placeholder="Directrices de marca o notas adicionales..."></textarea>
                                    </div>
                                </div>
                                <div class="mt-5 border-2 border-dashed border-slate-300 rounded-xl p-8 text-center hover:bg-slate-100 transition-colors cursor-pointer bg-white">
                                    <i data-lucide="upload" class="h-6 w-6 text-slate-400 mx-auto mb-3"></i>
                                    <span class="block text-sm text-slate-800 mb-1 font-semibold">Cargar insumos gráficos</span>
                                    <span class="block text-xs text-slate-500">Arrastrar archivos aquí</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Submit -->
                <div class="pt-4 border-t border-slate-200">
                    <button type="submit" class="w-full md:w-auto px-8 py-3.5 bg-[#00205B] text-white text-sm font-bold rounded-xl hover:bg-[#00153D] hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 shadow-md shadow-[#00205B]/30">
                        Generar Brief <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Script Lógica Vanilla JS -->
    <script>
        // Estado inicial
        let state = {
            nombreCurso: '',
            modalidad: 'E-learning Asincrónico',
            fechaInicio: '',
            siempreAbierto: false,
            horas: '',
            estudiantesMin: '',
            estudiantesMax: '',
            valor: '',
            hasSence: false,
            codigoSence: '',
            hasRelatores: false,
            relatores: [{ nombre: '', titulo: '', especialidad: '' }],
            relatorExclusivo: false,
            publicoObjetivo: '',
            dolorCliente: '',
            promesaValor: '',
            graficaEspecial: false,
            detalleGraficas: '',
            comentariosGrafica: ''
        };

        // Renderizado Dinámico Relatores
        function renderRelatores() {
            const container = document.getElementById('relatores-list');
            container.innerHTML = '';
            
            state.relatores.forEach((relator, index) => {
                const isDeleteDisabled = state.relatores.length === 1;
                const html = `
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 bg-white p-4 border border-slate-200 rounded-lg relative group shadow-sm">
                        <div class="md:col-span-5">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Nombres y Apellidos</label>
                            <input type="text" value="${relator.nombre}" onchange="updateRelator(${index}, 'nombre', this.value)" class="w-full bg-slate-50 border border-slate-200 rounded p-2 text-sm text-slate-900 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500" placeholder="Ej: Juan Pérez">
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Título</label>
                            <input type="text" value="${relator.titulo}" onchange="updateRelator(${index}, 'titulo', this.value)" class="w-full bg-slate-50 border border-slate-200 rounded p-2 text-sm text-slate-900 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500" placeholder="Ej: Ing. Comercial">
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Especialidad</label>
                            <input type="text" value="${relator.especialidad}" onchange="updateRelator(${index}, 'especialidad', this.value)" class="w-full bg-slate-50 border border-slate-200 rounded p-2 text-sm text-slate-900 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500" placeholder="Ej: Liderazgo">
                        </div>
                        <div class="md:col-span-1 flex items-end pb-1 justify-end">
                            <button type="button" onclick="removeRelator(${index})" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors" ${isDeleteDisabled ? 'disabled' : ''}>
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
            lucide.createIcons();
        }

        function updateRelator(index, field, value) {
            state.relatores[index][field] = value;
        }

        function addRelator() {
            state.relatores.push({ nombre: '', titulo: '', especialidad: '' });
            renderRelatores();
        }

        function removeRelator(index) {
            if (state.relatores.length > 1) {
                state.relatores.splice(index, 1);
                renderRelatores();
            }
        }

        // Lógica Condicional Visibilidad
        function updateUI() {
            // SENCE
            document.getElementById('container-codigoSence').classList.toggle('hidden', !state.hasSence);
            
            // Relatores Container & Sence Alert
            document.getElementById('container-relatores').classList.toggle('hidden', !state.hasRelatores);
            document.getElementById('container-reuf-sence').classList.toggle('hidden', !state.hasSence);
            
            // Gráficas
            document.getElementById('container-graficaDetalles').classList.toggle('hidden', !state.graficaEspecial);
            
            // Siempre abierto disable
            document.getElementById('fechaInicio').disabled = state.siempreAbierto;
        }

        // Vistas
        function setView(viewName) {
            document.getElementById('view-form').classList.add('hidden');
            document.getElementById('view-loading').classList.add('hidden');
            document.getElementById('view-report').classList.add('hidden');
            
            if (viewName === 'form') {
                document.getElementById('view-form').classList.remove('hidden');
                document.getElementById('view-form').classList.add('block');
            } else if (viewName === 'loading') {
                document.getElementById('view-loading').classList.remove('hidden');
                document.getElementById('view-loading').classList.add('flex');
            } else if (viewName === 'report') {
                populateReport();
                document.getElementById('view-report').classList.remove('hidden');
                document.getElementById('view-report').classList.add('block');
            }
        }

        function populateReport() {
            document.getElementById('rep-curso').textContent = state.nombreCurso || '—';
            document.getElementById('rep-modalidad').textContent = state.modalidad;
            document.getElementById('rep-inicio').textContent = state.siempreAbierto ? 'Siempre Abierto' : (state.fechaInicio || '—');
            document.getElementById('rep-horas').textContent = state.horas ? `${state.horas} hrs` : '—';
            document.getElementById('rep-valor').textContent = `$${state.valor || '0'}`;
            document.getElementById('rep-quorum').textContent = `${state.estudiantesMin || '—'} min / ${state.estudiantesMax || '—'} max`;

            document.getElementById('rep-sence').textContent = state.hasSence ? `Aprobado (Cód: ${state.codigoSence})` : 'Sin Franquicia SENCE';
            
            // Relatores
            const repRelatores = document.getElementById('rep-relatores-container');
            repRelatores.innerHTML = '';
            if (!state.hasRelatores) {
                repRelatores.innerHTML = '<span class="font-semibold text-slate-900">No se especifican relatores.</span>';
            } else {
                state.relatores.forEach(r => {
                    repRelatores.insertAdjacentHTML('beforeend', `
                        <div class="bg-slate-50 p-2.5 border border-slate-100 rounded text-slate-900">
                            <div class="font-semibold">${r.nombre || 'Sin nombre'}</div>
                            <div class="text-xs text-slate-500">${r.titulo || 'Sin título'} • ${r.especialidad || 'Sin especialidad'}</div>
                        </div>
                    `);
                });
            }

            // REUF alert
            const showReuf = state.hasSence && state.hasRelatores && state.relatorExclusivo;
            document.getElementById('rep-reuf-alert').classList.toggle('hidden', !showReuf);

            document.getElementById('rep-publico').textContent = state.publicoObjetivo || '—';
            document.getElementById('rep-dolor').textContent = state.dolorCliente || '—';
            document.getElementById('rep-promesa').textContent = state.promesaValor || '—';

            document.getElementById('rep-grafica-status').textContent = state.graficaEspecial ? 'Sí, requiere desarrollo.' : 'No (Usar gráficas estandar).';
            document.getElementById('rep-grafica-details').classList.toggle('hidden', !state.graficaEspecial);
            document.getElementById('rep-formatos').textContent = state.detalleGraficas || '—';
            document.getElementById('rep-comentarios').textContent = state.comentariosGrafica || '—';
        }

        // Export PDF
        async function handlePrint() {
            const btn = document.getElementById('btn-export-pdf');
            const iconDownload = document.getElementById('icon-download');
            const iconLoading = document.getElementById('icon-loading');
            const textExport = document.getElementById('text-export');
            
            btn.disabled = true;
            iconDownload.classList.add('hidden');
            iconLoading.classList.remove('hidden');
            textExport.textContent = 'Generando PDF...';

            try {
                const element = document.getElementById('report-content');
                const filenameStr = state.nombreCurso ? state.nombreCurso.replace(/[^a-z0-9]/gi, '_') : 'Campana';
                
                const opt = {
                    margin: [10, 10, 10, 10],
                    filename: `Brief_${filenameStr}.pdf`,
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };

                await html2pdf().set(opt).from(element).save();
            } catch (error) {
                console.error("Error al exportar PDF:", error);
            } finally {
                btn.disabled = false;
                iconDownload.classList.remove('hidden');
                iconLoading.classList.add('hidden');
                textExport.textContent = 'Exportar a PDF';
            }
        }

        // Init
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            renderRelatores();

            // Setup listeners para todos los inputs
            const inputs = ['nombreCurso', 'modalidad', 'fechaInicio', 'horas', 'valor', 'estudiantesMin', 'estudiantesMax', 'codigoSence', 'publicoObjetivo', 'dolorCliente', 'promesaValor', 'detalleGraficas', 'comentariosGrafica'];
            inputs.forEach(id => {
                document.getElementById(id).addEventListener('input', (e) => {
                    state[id] = e.target.value;
                });
            });

            const checks = ['siempreAbierto', 'hasSence', 'hasRelatores', 'relatorExclusivo', 'graficaEspecial'];
            checks.forEach(id => {
                document.getElementById(id).addEventListener('change', (e) => {
                    state[id] = e.target.checked;
                    updateUI();
                });
            });

            document.getElementById('main-form').addEventListener('submit', (e) => {
                e.preventDefault();
                setView('loading');
                setTimeout(() => {
                    setView('report');
                }, 1200);
            });
        });

    </script>
</body>
</html>
